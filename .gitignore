# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
build/
out/

# tsc emit leaking into src/ — never commit. Generated output belongs in dist/.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
# Re-allow hand-authored ambient declarations (not tsc emit).
!packages/cli/src/declarations.d.ts
!packages/cli/src/optional-modules.d.ts
!packages/mobile/src/optional-modules.d.ts

# ─── Next.js ──────────────────────────────────────────────────────────────────
.next/
.vercel/

# ─── Turborepo cache ──────────────────────────────────────────────────────────
.turbo/

# ─── Vitest / Vite cache ──────────────────────────────────────────────────────
.vite/
coverage/

# ─── Environment / secrets — never commit ─────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── TypeScript incremental build ────────────────────────────────────────────
*.tsbuildinfo
