{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "echo 'static site — no build required'",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/status",      "destination": "/status/index.html" },
    { "source": "/status/",     "destination": "/status/index.html" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
