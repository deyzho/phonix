{
  "name": "@axonsdk/sdk",
  "version": "0.3.0",
  "description": "Provider-abstracted SDK for routing AI inference across edge and cloud compute — io.net, Akash, Acurast, Fluence, Koii, AWS, GCP, Azure, Cloudflare, and Fly.io.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./runtime/global": {
      "types": "./dist/runtime/global.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "inference",
    "edge-compute",
    "routing",
    "sdk",
    "llm",
    "openai",
    "gpu",
    "ionet",
    "akash",
    "acurast",
    "fluence",
    "koii",
    "aws",
    "cloudflare",
    "multi-provider",
    "tee",
    "depin"
  ],
  "author": "AxonSDK <deyzho@me.com>",
  "license": "Apache-2.0",
  "homepage": "https://axonsdk.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/deyzho/axonsdk-ts.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/deyzho/axonsdk-ts/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@acurast/dapp": "1.0.1",
    "esbuild": "^0.20.0"
  },
  "optionalDependencies": {
    "@fluencelabs/cli": "^0.15.0",
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
