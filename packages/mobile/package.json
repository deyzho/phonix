{
  "name": "@phonix/mobile",
  "version": "0.2.0",
  "description": "React Native / Expo bindings for the Phonix SDK — iOS and Android support",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "echo 'source-only package — nothing to clean'"
  },
  "dependencies": {
    "@phonix/sdk": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "expo-secure-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "keywords": [
    "phonix",
    "react-native",
    "expo",
    "ios",
    "android",
    "depin",
    "edge-compute",
    "acurast",
    "akash"
  ]
}
