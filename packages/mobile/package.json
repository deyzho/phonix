{
  "name": "@axonsdk/mobile",
  "version": "0.2.2",
  "description": "React Native / Expo SDK for calling AI inference endpoints from iOS and Android apps — with automatic routing, failover, and secure key storage.",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "echo 'source-only package — nothing to clean'"
  },
  "keywords": [
    "axon",
    "ai",
    "inference",
    "react-native",
    "expo",
    "ios",
    "android",
    "edge-compute",
    "routing",
    "gpu",
    "acurast",
    "akash",
    "multi-provider",
    "depin"
  ],
  "author": "Axon <hello@axon.dev>",
  "license": "Apache-2.0",
  "homepage": "https://axon.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/deyzho/axonsdk.git",
    "directory": "packages/mobile"
  },
  "bugs": {
    "url": "https://github.com/deyzho/axonsdk/issues"
  },
  "files": [
    "src",
    "!src/__tests__",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@axonsdk/sdk": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "expo-secure-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
