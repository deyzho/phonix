{
  "name": "@axonsdk/mobile",
  "version": "0.2.7",
  "description": "React Native / Expo SDK for calling AI inference endpoints from iOS and Android apps — with automatic routing, failover, and secure key storage.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "axon",
    "ai",
    "inference",
    "react-native",
    "expo",
    "ios",
    "android",
    "edge-compute",
    "routing",
    "gpu",
    "acurast",
    "akash",
    "multi-provider"
  ],
  "author": "AxonSDK <deyzho@me.com>",
  "license": "Apache-2.0",
  "homepage": "https://axonsdk.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/deyzho/axon-ts.git",
    "directory": "packages/mobile"
  },
  "bugs": {
    "url": "https://github.com/deyzho/axon-ts/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@axonsdk/sdk": "^0.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "expo-secure-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
